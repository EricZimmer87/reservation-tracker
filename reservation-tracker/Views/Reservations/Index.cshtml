@model reservation_tracker.Models.ViewModels.Reservations.ReservationIndexPageViewModel

@{
    ViewData["Title"] = "Reservations";

    var title =
        Model.Scope?.Equals("past", StringComparison.OrdinalIgnoreCase) == true ? "Past Reservations" :
        Model.Scope?.Equals("all", StringComparison.OrdinalIgnoreCase) == true ? "All Reservations" :
        "Current Reservations";

}

<h1>@title</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New Reservation</a>
</p>

<!-- Search -->
<h4>Search and Filter Reservations</h4>
<form method="get" asp-action="Index" class="row g-2 mb-3">
    <input type="hidden" name="sort" value="@Model.CurrentSort" />
    <input type="hidden" name="dir" value="@Model.CurrentDir" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
    <input type="hidden" name="scope" value="@Model.Scope" />
    <input type="hidden" name="page" value="1" />

    <div class="col-auto">
        <label for="search" class="form-label mb-0">Search</label>
        <input id="search"
               type="text"
               name="search"
               value="@Model.Search"
               class="form-control"
               placeholder="Search reservations..." />
    </div>

    <div class="col-auto">
        <label class="form-label mb-0">Reserved On Date Range</label>
        <div class="d-flex gap-2">
            <input type="date"
                   name="reservedFrom"
                   value="@(Model.ReservedFrom?.ToString("yyyy-MM-dd"))"
                   class="form-control" />
            <input type="date"
                   name="reservedTo"
                   value="@(Model.ReservedTo?.ToString("yyyy-MM-dd"))"
                   class="form-control" />
        </div>
    </div>

    <div class="col-auto">
        <label class="form-label mb-0">Stay Date Range</label>
        <div class="d-flex gap-2">
            <input type="date"
                   name="stayFrom"
                   value="@(Model.StayFrom?.ToString("yyyy-MM-dd"))"
                   class="form-control" />
            <input type="date"
                   name="stayTo"
                   value="@(Model.StayTo?.ToString("yyyy-MM-dd"))"
                   class="form-control" />
        </div>
    </div>

    <div class="col-auto d-flex align-items-end gap-2">
        <button class="btn btn-primary" type="submit">Apply</button>

        <a class="btn btn-outline-secondary"
           asp-action="Index"
           asp-route-pageSize="@Model.PageSize">
            Clear
        </a>
    </div>
</form>

@await Html.PartialAsync("_ReservationsTable", Model)


