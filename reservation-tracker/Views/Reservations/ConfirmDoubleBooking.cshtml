@model reservation_tracker.Models.ViewModels.Reservations.ConfirmDoubleBookingViewModel

@{
    ViewData["Title"] = "Confirm Double-Booking";

    var actionName = Model.Reservation.ConfirmAction ?? "Create";
}

<h1>Confirm Double-Booking</h1>

<div class="alert alert-warning">
    <strong>Warning:</strong>
    This reservation overlaps with one or more existing non-canceled reservations
    for the same room.
</div>

<p>
    Do you want to continue anyway?
</p>

<h3>Reservation Being Submitted</h3>
<dl class="row">
    <dt class="col-sm-3">Room</dt>
    <dd class="col-sm-9">@Model.Reservation.RoomNumber</dd>

    <dt class="col-sm-3">Guest</dt>
    <dd class="col-sm-9">@Model.Reservation.GuestFullName</dd>

    <dt class="col-sm-3">Phone Number</dt>
    <dd class="col-sm-9">@Model.Reservation.PhoneNumber</dd>

    <dt class="col-sm-3">Check-in</dt>
    <dd class="col-sm-9">@Model.Reservation.CheckInDate</dd>

    <dt class="col-sm-3">Check-out</dt>
    <dd class="col-sm-9">@Model.Reservation.CheckOutDate</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Reservation.Status</dd>
</dl>

<h3>Conflicting Reservations</h3>

@if (Model.OverlappingReservations.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Guest</th>
                <th>Phone Number</th>
                <th>Room</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.OverlappingReservations)
            {
                <tr>
                    <td>@r.Guest?.LastName, @r.Guest?.FirstName</td>
                    <td>@r.Guest?.PhoneNumber</td>
                    <td>@r.Room.RoomNumber</td>
                    <td>@r.CheckInDate</td>
                    <td>@r.CheckOutDate</td>
                    <td>@r.Status</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3 d-flex gap-2">
    <!-- YES: submit again, but this time with ConfirmDoubleBooking = true -->
    <form asp-action="ConfirmDoubleBooking" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Reservation.ReservationId" />
        <input type="hidden" asp-for="Reservation.GuestId" />
        <input type="hidden" asp-for="Reservation.RoomId" />
        <input type="hidden" asp-for="Reservation.CheckInDate" />
        <input type="hidden" asp-for="Reservation.CheckOutDate" />
        <input type="hidden" asp-for="Reservation.NumberOfGuests" />
        <input type="hidden" asp-for="Reservation.Notes" />
        <input type="hidden" asp-for="Reservation.Status" />
        <input type="hidden" asp-for="Reservation.CardLastFour" />
        <input type="hidden" asp-for="Reservation.ReturnUrl" />
        <input type="hidden" asp-for="Reservation.GuestReturnUrl" />
        <input type="hidden" asp-for="Reservation.ConfirmAction" />
        <input type="hidden" asp-for="Reservation.ConfirmDoubleBooking" value="true" />

        <button type="submit" class="btn btn-danger">Yes, continue</button>
    </form>

    <!-- NO: go back to the form -->
    <form asp-action="CancelDoubleBookingConfirmation" method="post">
        @Html.AntiForgeryToken()

        @if (actionName == "Edit" && Model.Reservation.ReservationId.HasValue)
        {
            <input type="hidden" name="id" value="@Model.Reservation.ReservationId.Value" />
        }

        <input type="hidden" asp-for="Reservation.ReservationId" />
        <input type="hidden" asp-for="Reservation.GuestId" />
        <input type="hidden" asp-for="Reservation.RoomId" />
        <input type="hidden" asp-for="Reservation.CheckInDate" />
        <input type="hidden" asp-for="Reservation.CheckOutDate" />
        <input type="hidden" asp-for="Reservation.NumberOfGuests" />
        <input type="hidden" asp-for="Reservation.Notes" />
        <input type="hidden" asp-for="Reservation.Status" />
        <input type="hidden" asp-for="Reservation.CardLastFour" />
        <input type="hidden" asp-for="Reservation.ReturnUrl" />
        <input type="hidden" asp-for="Reservation.GuestReturnUrl" />
        <input type="hidden" asp-for="Reservation.ConfirmAction" />

        <button type="submit" class="btn btn-secondary">No, go back</button>
    </form>
</div>