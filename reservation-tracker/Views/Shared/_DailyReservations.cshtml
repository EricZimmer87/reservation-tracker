@model reservation_tracker.Models.ViewModels.Reservations.DailyReservationsViewModel

@{
    var prevDay = Model.SelectedDay.AddDays(-1);
    var nextDay = Model.SelectedDay.AddDays(1);
    var prevMonth = Model.SelectedDay.AddMonths(-1);
    var nextMonth = Model.SelectedDay.AddMonths(1);

    // For <input type="date">
    var selectedDayValue = Model.SelectedDay.ToString("yyyy-MM-dd");

    // Context is current HTTP context - Gets path + query to construct the URL
    var returnUrl = Context.Request.Path + Context.Request.QueryString;

    // Summary info
    var totalRooms = Model.Rooms.Count;
    var occupiedCount = Model.Rooms.Count(x => x.IsOccupied);
    var vacantCount = totalRooms - occupiedCount;
    var vacantRoomList = string.Join(", ",
        Model.Rooms
            .Where(x => !x.IsOccupied)
            .Select(x => x.RoomNumber));
}

<h1>Daily Reservations</h1>
<!-- Date picker (GET) -->
<div class="d-flex align-items-center gap-2 mb-3">
    <form asp-action="Index" method="get" class="d-flex align-items-center gap-2 mb-0">
        <input class="form-control"
               type="date"
               name="selectedDay"
               value="@selectedDayValue" />

        <div class="form-check">
            <input class="form-check-input"
                   type="checkbox"
                   name="showCanceled"
                   value="true"
                   id="showCanceled"
                   checked="@Model.ShowCanceled" />
            <label class="form-check-label" for="showCanceled">
                Show canceled
            </label>
        </div>

        <button class="btn btn-primary" type="submit">Go</button>
    </form>
</div>

<div class="d-flex align-items-center gap-2 mb-3">
    <!-- Prev month -->
    <a class="btn btn-outline-secondary"
       asp-action="Index"
       asp-route-selectedDay="@prevMonth"
       asp-route-showCanceled="@Model.ShowCanceled"
       title="Previous month">
        &laquo;
        Prev Month
    </a>

    <!-- Prev day -->
    <a class="btn btn-outline-secondary"
       asp-action="Index"
       asp-route-selectedDay="@prevDay"
       asp-route-showCanceled="@Model.ShowCanceled"
       title="Previous day">
        &lsaquo;
        Prev Day
    </a>

    <!-- Next day -->
    <a class="btn btn-outline-secondary"
       asp-action="Index"
       asp-route-selectedDay="@nextDay"
       asp-route-showCanceled="@Model.ShowCanceled"
       title="Next day">
        Next Day
        &rsaquo;
    </a>

    <!-- Next month -->
    <a class="btn btn-outline-secondary"
       asp-action="Index"
       asp-route-selectedDay="@nextMonth"
       asp-route-showCanceled="@Model.ShowCanceled"
       title="Next month">
        Next Month
        &raquo;
    </a>

    <span class="ms-2 text-muted">
        @Model.SelectedDay.ToString("dddd, MMM d, yyyy")
    </span>
</div>

<!-- Summary Info -->
<div class="mb-3">
    <div class="d-flex flex-wrap align-items-center gap-2">
        <span class="badge bg-dark">Total: @totalRooms</span>
        <span class="badge bg-success">Occupied: @occupiedCount</span>
        <span class="badge bg-secondary">Vacant: @vacantCount</span>
    </div>

    <div class="mt-2">
        <strong>Vacant rooms:</strong>
        @if (vacantCount == 0)
        {
            <span>None</span>
        }
        else
        {
            <span>@vacantRoomList</span>
        }
    </div>
</div>

<table class="table table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>Room</th>
            <th>Date Reserved</th>
            <th>Guest</th>
            <th>Address</th>
            <th>Phone Number</th>
            <th>Check-In</th>
            <th>Check-Out</th>
            <th>Guests</th>
            <th>Status</th>
            <th>Notes</th>
            <th>Card</th>
            <th>Reserved By</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Model.Rooms)
        {
            if (!row.Reservations.Any())
            {
                <tr>
                    <td class="fw-bold">@row.RoomNumber</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td><span class="badge bg-success">Vacant</span></td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>
                        <a asp-controller="Reservations"
                               asp-action="Create"
                               asp-route-roomId="@row.RoomId"
                               asp-route-checkInDate="@selectedDayValue"
                               asp-route-returnUrl="@returnUrl">
                            Create
                        </a>
                    </td>
                </tr>
            }
            else
            {
                foreach (var r in row.Reservations)
                {
                    <tr class="@(row.IsDoubleBooked ? "table-danger" : "")">
                        <td class="fw-bold">
                            @row.RoomNumber
                            @if (row.IsDoubleBooked)
                            {
                                <div class="text-danger fw-bold">⚠ Double-booked</div>
                            }
                        </td>

                        <td>@r.DateReserved.ToString("g")</td>

                        <td>
                            @if (!string.IsNullOrWhiteSpace(r.GuestFullName) && r.GuestId != null)
                            {
                                <a asp-controller="Guests"
                                       asp-action="Details"
                                       asp-route-id="@r.GuestId"
                                       asp-route-returnUrl="@returnUrl">
                                    @r.GuestFullName
                                </a>
                            }
                            else
                            {
                                @:-
                            }
                        </td>

                        <td>@(r.GuestFullAddress ?? "-")</td>
                        <td>@(r.GuestPhoneNumber ?? "-")</td>
                        <td>@r.CheckInDate.ToString("MM/dd/yyyy")</td>
                        <td>@r.CheckOutDate.ToString("MM/dd/yyyy")</td>
                        <td>@(r.NumberOfGuests?.ToString() ?? "-")</td>

                        <td>
                            @if (string.Equals(r.Status, "Canceled", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="fw-bold text-danger">@r.Status</span>
                            }
                            else
                            {
                                @r.Status
                            }
                        </td>

                        <td>@(r.Notes ?? "-")</td>
                        <td>@(r.CardLastFour ?? "-")</td>
                        <td>@(r.ReservedByDisplayName ?? "-")</td>

                        <td>
                            <a asp-controller="Reservations"
                                   asp-action="Edit"
                                   asp-route-id="@r.ReservationId"
                                   asp-route-returnUrl="@returnUrl"
                                   class="me-2">
                                Edit
                            </a>

                            <a asp-controller="Reservations"
                                   asp-action="Details"
                                   asp-route-id="@r.ReservationId"
                                   asp-route-returnUrl="@returnUrl">
                                Details
                            </a>
                        </td>
                    </tr>
                }
            }
        }
    </tbody>
</table>