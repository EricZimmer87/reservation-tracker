@model reservation_tracker.Models.ViewModels.Reservations.DailyReservationsViewModel

@{
    var prevDay = Model.SelectedDay.AddDays(-1);
    var nextDay = Model.SelectedDay.AddDays(1);
    var prevMonth = Model.SelectedDay.AddMonths(-1);
    var nextMonth = Model.SelectedDay.AddMonths(1);

    // For <input type="date">
    var selectedDayValue = Model.SelectedDay.ToString("yyyy-MM-dd");

    // Summary info
    var totalRooms = Model.Rooms.Count;
    var occupiedRooms = Model.Rooms.Where(x => x.Reservation is not null).ToList();
    var vacantRooms = Model.Rooms.Where(x => x.Reservation is null).ToList();

    var occupiedCount = occupiedRooms.Count;
    var vacantCount = vacantRooms.Count;

    var vacantRoomList = string.Join(", ", vacantRooms.Select(x => x.RoomNumber));
}

<h1>Daily Reservations</h1>
<div class="d-flex align-items-center gap-2 mb-3">
    <!-- Prev month -->
    <a class="btn btn-outline-secondary"
       asp-action="Index"
       asp-route-selectedDay="@prevMonth"
       title="Previous month">
        &laquo;
        Prev Month
    </a>

    <!-- Prev day -->
    <a class="btn btn-outline-secondary"
       asp-action="Index"
       asp-route-selectedDay="@prevDay"
       title="Previous day">
        &lsaquo;
        Prev Day
    </a>

    <!-- Date picker (GET) -->
    <form asp-action="Index" method="get" class="d-flex align-items-center gap-2 mb-0">
        <input class="form-control"
               type="date"
               name="selectedDay"
               value="@selectedDayValue" />

        <button class="btn btn-primary" type="submit">Go</button>
    </form>

    <!-- Next day -->
    <a class="btn btn-outline-secondary"
       asp-action="Index"
       asp-route-selectedDay="@nextDay"
       title="Next day">
        Next Day
        &rsaquo;
    </a>

    <!-- Next month -->
    <a class="btn btn-outline-secondary"
       asp-action="Index"
       asp-route-selectedDay="@nextMonth"
       title="Next month">
        Next Month
        &raquo;
    </a>

    <span class="ms-2 text-muted">
        @Model.SelectedDay.ToString("dddd, MMM d, yyyy")
    </span>
</div>

<!-- Summary Info -->
<div class="mb-3">
    <div class="d-flex flex-wrap align-items-center gap-2">
        <span class="badge bg-dark">Total: @totalRooms</span>
        <span class="badge bg-success">Occupied: @occupiedCount</span>
        <span class="badge bg-secondary">Vacant: @vacantCount</span>
    </div>

    <div class="mt-2">
        <strong>Vacant rooms:</strong>
        @if (vacantCount == 0)
        {
            <span>None</span>
        }
        else
        {
            <span>@vacantRoomList</span>
        }
    </div>
</div>

<table class="table table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>Room</th>
            <th>Date Reserved</th>
            <th>Guest</th>
            <th>Address</th>
            <th>Phone Number</th>
            <th>Check-In</th>
            <th>Check-Out</th>
            <th>Guests</th>
            <th>Status</th>
            <th>Notes</th>
            <th>Card</th>
            <th>Reserved By</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Model.Rooms)
        {
            var r = row.Reservation;

            <tr>
                <td class="fw-bold">@row.RoomNumber</td>
                <td>@(r?.DateReserved.ToString("g") ?? "-")</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(r?.GuestFullName) && r?.GuestId != null)
                    {
                        <a asp-controller="Guests"
                           asp-action="Details"
                           asp-route-id="@r.GuestId">
                            @r.GuestFullName
                        </a>
                    }
                    else
                    {
                        @:-
                    }
                </td>
                <td>@(r?.GuestFullAddress ?? "-")</td>
                <td>@(r?.GuestPhoneNumber ?? "-")</td>

                <td>@(r is null ? "-" : r.CheckInDate.ToString("MM/dd/yyyy"))</td>

                <td>@(r is null ? "-" : r.CheckOutDate.ToString("MM/dd/yyyy"))</td>

                <td>@(r?.NumberOfGuests?.ToString() ?? "-")</td>

                <td>
                    @if (r is null)
                    {
                        <span class="badge bg-success">Vacant</span>
                    }
                    else if (r.Status.Equals("Canceled", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="fw-bold text-danger">@r.Status</span>
                    }
                    else
                    {
                        @r.Status
                    }
                </td>

                <td>@(r?.Notes ?? "-")</td>

                <td>@(r?.CardLastFour ?? "-")</td>

                <td>@(r?.ReservedByDisplayName ?? "-")</td>

                <td>
                    @if (r is null)
                    {
                        <a asp-controller="Reservations"
                           asp-action="Create"
                           asp-route-roomId="@row.RoomId"
                           asp-route-checkInDate="@selectedDayValue">
                            Create
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Reservations"
                           asp-action="Edit"
                           asp-route-id="@r.ReservationId"
                           class="me-2">Edit</a>

                        <a asp-controller="Reservations"
                           asp-action="Details"
                           asp-route-id="@r.ReservationId">Details</a>
                                }
                </td>
            </tr>
        }
    </tbody>
</table>