@model IEnumerable<Guest>
@{
    var returnUrl = (string)ViewBag.ReturnUrl;
}

<form method="get" asp-action="Search">
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <input type="text" name="q" value="@Context.Request.Query["q"]" placeholder="Search guests..." />
    <button type="submit">Search</button>
</form>

<table class="table">
    <tbody>
        @foreach (var g in Model)
        {
            <tr>
                <td>@g.LastName, @g.FirstName</td>
                <td>@g.Email</td>
                <td>@g.PhoneNumber</td>
                <td>
                    <a asp-action="Select"
                       asp-route-guestId="@g.GuestId"
                       asp-route-returnUrl="@returnUrl">
                        Select
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
